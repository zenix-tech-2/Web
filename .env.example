# --- Client-side (exposed in the browser bundle — never put secrets here) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_VAPID_PUBLIC_KEY=

# --- Server-side only (read in /api functions via process.env, NOT import.meta.env) ---
# Do NOT prefix these with VITE_ — that prefix tells Vite to inline the value
# into the public JS bundle.
ASHTECHPAY_PUBLIC_KEY=
ASHTECHPAY_SECRET_KEY=
SUPABASE_SERVICE_KEY=
